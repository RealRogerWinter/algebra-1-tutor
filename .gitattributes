# The data tables in these two files are generated LF-only by
# _verification/generate.py. Pin them to LF so Windows checkouts (autocrlf)
# don't show spurious whole-file CRLF diffs after running the generator.
algebra-1-tutor/references/curriculum-map.md text eol=lf
docs/CURRICULUM.md text eol=lf

# Figures are generated LF-only by _verification/figures.py; pin so regeneration
# doesn't show spurious CRLF diffs on Windows checkouts.
algebra-1-tutor/figures/*.svg text eol=lf

# The HTML textbook is generated LF-only by _verification/build_textbook.py.
docs/textbook/** text eol=lf

# The tutor guide is generated LF-only by _verification/build_tutor_guide.py.
docs/tutor-guide/** text eol=lf

# The student guide is generated LF-only by _verification/build_student_guide.py.
docs/student-guide/** text eol=lf

# The GitHub Pages landing page is generated LF-only by _verification/build_landing.py.
docs/index.html text eol=lf
docs/textbook.css text eol=lf
